DATABASE_URL=postgres://ashlyn:ashlyn@localhost:5432/ashlyn
DATABASE_URL_TEST=postgres://ashlyn:ashlyn@localhost:5432/ashlyn_test

# NextAuth — generate AUTH_SECRET with `openssl rand -base64 32`
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend (https://resend.com) for magic-link email
AUTH_RESEND_KEY=
AUTH_RESEND_FROM=auth@yourdomain.com

# Stripe — use test-mode keys until BD-006 ships + QA
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# HMAC secret for signed URLs to gated content (BD-007)
# Generate with `openssl rand -base64 32`
SIGNED_URL_SECRET=
