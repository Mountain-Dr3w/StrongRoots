{
  "name": "ashlyn-training",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:up": "docker compose -f docker-compose.dev.yml up -d && docker compose -f docker-compose.dev.yml exec -T postgres sh -c 'until pg_isready -U ashlyn; do sleep 0.5; done'",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx --env-file=.env.local src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@hookform/resolvers": "^5.2.2",
    "@react-email/components": "^1.0.12",
    "@stripe/stripe-js": "^9.2.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "graphile-worker": "^0.16.6",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "next-pwa": "^5.6.0",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "resend": "^6.12.0",
    "stripe": "^22.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
